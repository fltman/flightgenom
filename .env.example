# ── flightgenom configuration ──────────────────────────────────────────────
# Copy to .env and edit. All values are optional; sensible defaults are used.

PORT=8099

# Data source: sim | adsblol | adsbfi | airplaneslive | opensky | aeroapi
#   sim          → synthetic airline network with cascading delays (DELAY GENOME demo)
#   adsblol      → real live ADS-B around a point (ODbL; recommended free live feed)
#   adsbfi       → real live ADS-B around a point (non-commercial)
#   airplaneslive→ real live ADS-B around a point (non-commercial)
#   opensky      → real live ADS-B over a bounding box (research/non-profit only)
#   aeroapi      → REAL flights WITH a real delay genome via FlightAware AeroAPI
#                  (pay-per-query; needs AEROAPI_KEY; uses BBOX below)
DATA_SOURCE=sim
POLL_INTERVAL_MS=2000

# Default color mode: genome | delay | altitude
COLOR_MODE=genome

# ── sim engine ───────────────────────────────────────────────────────────────
SIM_FLEET=70          # number of aircraft in the synthetic network
SIM_SPEED=1           # time multiplier (1 = realtime; >1 accelerates, less smooth)

# ── live ADS-B: OpenSky (region bounding box: West,South,East,North) ──────────
BBOX=-11,35,30,62
# OpenSky moved to OAuth2 client-credentials in 2025. Anonymous access is heavily
# rate-limited; register a free app to get these and raise your quota.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# ── live ADS-B: airplanes.live (point query, radius in nautical miles ≤250) ───
CENTER=59.3293,18.0686
RADIUS_NM=250

# ── REAL delay genome: FlightAware AeroAPI (DATA_SOURCE=aeroapi) ──────────────
# Pay-per-query. Set DATA_SOURCE=aeroapi and your key below. The live search
# uses the BBOX above; keep the box small to control cost. See the README
# section "Real genome via AeroAPI" for the rotation approach and cost notes.
AEROAPI_KEY=

# ── delay enrichment for LIVE sources only: none | mock | aviationstack ───────
# (Ignored for sim and aeroapi, which already carry their own delay + genome.)
SCHEDULE_SOURCE=none
AVIATIONSTACK_KEY=

# ── AI network analyst (OpenRouter) ──────────────────────────────────────────
# Powers the "AI briefing" panel: summary, conclusions, predictions, and the
# narrow sensitive points (chokepoints). Needs an OpenRouter key. The model is
# also switchable live in the UI; this is just the default.
OPENROUTER_API_KEY=
ANALYST_MODEL=anthropic/claude-opus-4.8
